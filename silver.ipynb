   "source": [
    "from pyspark.sql.functions import col, to_date, current_timestamp\n",
    "from pyspark.sql.types import DoubleType, IntegerType\n",
    "\n",
    "# Path to your Bronze data (assuming it was saved as Parquet or Delta)\n",
    "bronze_path = \"wasbs://<contianer>@<storage_account>.blob.core.windows.net/bronze\"\n",
    "\n",
    "# 1. Read data from the Bronze layer\n",
    "# Based on your retail_dataset.csv schema: order_id, customer_id, product, category, etc.\n",
    "bronze_df = spark.read.format(\"parquet\").load(bronze_path)\n",
    "\n",
    "# 2. Data Transformation and Cleaning\n",
    "# - Convert 'order_date' to a proper Date type\n",
    "# - Cast numeric columns to ensure mathematical accuracy\n",
    "# - Add a processing timestamp for audit purposes\n",
    "silver_df = bronze_df.withColumn(\"order_date\", to_date(col(\"order_date\"), \"yyyy-MM-dd\")) \\\n",
    "                     .withColumn(\"price\", col(\"price\").cast(DoubleType())) \\\n",
    "                     .withColumn(\"quantity\", col(\"quantity\").cast(IntegerType())) \\\n",
    "                     .withColumn(\"total_amount\", col(\"total_amount\").cast(DoubleType())) \\\n",
    "                     .withColumn(\"processed_at\", current_timestamp())\n",
    "\n",
    "# 3. Write to Silver container as a Delta table [cite: 95]\n",
    "# Delta format is required for the Lakehouse architecture performance [cite: 58]\n",
    "silver_output_path = \"wasbs://<contianer>@<storage_account>.blob.core.windows.net/silver\"\n",
    "silver_df.write.format(\"delta\") \\\n",
    "    .mode(\"overwrite\") \\\n",
    "    .option(\"overwriteSchema\", \"true\") \\\n",
    "    .save(silver_output_path)\n",
    "\n",
    "print(\"Silver Layer processing complete.\")"
   ]
  }
