   "source": [
    "from pyspark.sql.functions import sum, count, avg\n",
    "\n",
    "# Path to the cleaned Silver data\n",
    "silver_path = \"wasbs://d<contianer>@<storage_account>.blob.core.windows.net/silver\"\n",
    "\n",
    "# 1. Read the cleaned data from Silver\n",
    "silver_df = spark.read.format(\"delta\").load(silver_path)\n",
    "\n",
    "# 2. Generate Business Insights (Gold Table)\n",
    "# Aggregating sales revenue and order counts by Category and City \n",
    "gold_sales_summary = silver_df.groupBy(\"category\", \"city\") \\\n",
    "    .agg(\n",
    "        sum(\"total_amount\").alias(\"total_revenue\"),\n",
    "        count(\"order_id\").alias(\"total_orders\"),\n",
    "        avg(\"price\").alias(\"average_unit_price\")\n",
    "    )\n",
    "\n",
    "# 3. Save to Gold container for Synapse and Power BI consumption [cite: 29, 30]\n",
    "gold_output_path = \"wasbs://<contianer>@<storage_account>.blob.core.windows.net/gold\"\n",
    "\n",
    "gold_sales_summary.write.format(\"delta\") \\\n",
    "    .mode(\"overwrite\") \\\n",
    "    .save(gold_output_path)\n",
    "\n",
    "print(\"Gold Layer processing complete. Data ready for Analytics.\")"
   ]
  }
 ],
